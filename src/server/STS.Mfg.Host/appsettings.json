{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "SqlServer": "Server=(localdb)\\MSSQLLocalDB;Database=STS_Mfg_Bootstrap;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Security": {
    "Issuer": "sts-mfg",
    "Audience": "sts-mfg-api",
    "RequireHttpsMetadata": true,
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "Storage": {
    "AttachmentsRoot": "App_Data\\attachments"
  },
  "BackgroundJobs": {
    "NotificationPollSeconds": 30,
    "NotificationBatchSize": 25
  },
  "Localization": {
    "DefaultLanguageCode": "en-IN"
  },
  "Integrations": {
    "Enabled": false,
    "ConfiguredProviders": []
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
